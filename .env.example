# MarketPulse Global Environment Template

# ==========================================
# 1. EXPRESS BACKEND SERVER (server/.env)
# ==========================================
PORT=5000
MONGO_URI=mongodb://localhost:27017/marketpulse
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret
NEWS_API_KEY=your_news_api_key_here
AI_SERVICE_URL=http://localhost:8000

# ==========================================
# 2. PYTHON FASTAPI SERVICE (ai-service/.env)
# ==========================================
PORT=8000
GEMINI_API_KEY=your_gemini_api_key_here
HF_API_KEY=your_hugging_face_token_here
